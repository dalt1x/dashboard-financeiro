generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum InternalCategory {
  ALIMENTACAO
  TRANSPORTE
  MORADIA
  LAZER
  SAUDE
  COMPRAS
  SALARIO
  TRANSFERENCIAS
  OUTROS
}

enum TransactionDirection {
  INCOME
  EXPENSE
}

model User {
  id           String         @id @default(cuid())
  name         String
  email        String         @unique
  passwordHash String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  budgets      Budget[]
  plaidItems   PlaidItem[]
  accounts     Account[]
  transactions Transaction[]
  syncLogs     SyncLog[]
}

model PlaidItem {
  id               String    @id @default(cuid())
  userId           String
  itemId           String    @unique
  accessToken      String
  syncCursor       String?
  institutionId    String?
  institutionName  String?
  lastSyncedAt     DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accounts         Account[]
  transactions     Transaction[]
  syncLogs         SyncLog[]

  @@index([userId])
}

model Account {
  id               String         @id @default(cuid())
  userId           String
  plaidItemId      String
  plaidAccountId   String         @unique
  name             String
  officialName     String?
  type             String
  subtype          String?
  mask             String?
  currentBalance   Decimal?       @db.Decimal(12, 2)
  availableBalance Decimal?       @db.Decimal(12, 2)
  isoCurrencyCode  String?        @default("USD")
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  plaidItem        PlaidItem      @relation(fields: [plaidItemId], references: [id], onDelete: Cascade)
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions     Transaction[]

  @@index([userId])
  @@index([plaidItemId])
}

model Transaction {
  id                String               @id @default(cuid())
  userId            String
  plaidItemId       String
  accountId         String
  plaidTransactionId String              @unique
  name              String
  merchantName      String?
  amount            Decimal              @db.Decimal(12, 2)
  isoCurrencyCode   String?              @default("USD")
  date              DateTime
  pending           Boolean              @default(false)
  categoryPrimary   String?
  categoryDetailed  String?
  internalCategory  InternalCategory     @default(OUTROS)
  customCategory    InternalCategory?
  direction         TransactionDirection
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  account           Account              @relation(fields: [accountId], references: [id], onDelete: Cascade)
  plaidItem         PlaidItem            @relation(fields: [plaidItemId], references: [id], onDelete: Cascade)
  user              User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([userId, internalCategory])
  @@index([accountId])
  @@index([plaidItemId])
}

model SyncLog {
  id            String    @id @default(cuid())
  userId        String
  plaidItemId   String?
  status        String
  accountsSynced Int      @default(0)
  transactionsSynced Int  @default(0)
  startedAt     DateTime  @default(now())
  finishedAt    DateTime?
  errorMessage  String?
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  plaidItem     PlaidItem? @relation(fields: [plaidItemId], references: [id], onDelete: SetNull)

  @@index([userId, startedAt])
  @@index([plaidItemId])
}

model Budget {
  id         String           @id @default(cuid())
  userId     String
  month      DateTime
  category   InternalCategory
  amount     Decimal          @db.Decimal(12, 2)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month, category])
  @@index([userId, month])
}
